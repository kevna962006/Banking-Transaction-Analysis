select *from customers;

select *from transactions;

select cus_id,name from customers where acc_bal>1500;

select *from transactions order by tra_date desc;

select distinct tra_mode from transactions;

select *from transactions order by amount desc limit 5;

select *from customers where name like 'A%';

select cus_id,sum(amount) from transactions group by cus_id;

select cus_id,sum(amount) from transactions group by cus_id having sum(amount)>2000;

select c.name,t.amount,t.tra_type from customers c join transactions t on c.cus_id=t.cus_id;

select cus_id,amount,sum(amount) over(partition by cus_id order by tra_date) as running_total from transactions;

SELECT name, acc_bal,
DENSE_RANK() OVER(ORDER BY acc_bal DESC) AS rank_no
FROM customers;

SELECT cus_id
FROM transactions
GROUP BY cus_id
HAVING AVG(amount) >
      (SELECT AVG(amount) FROM transactions);
