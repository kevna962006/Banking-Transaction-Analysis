CREATE DATABASE bank_system;

USE bank_system;

CREATE TABLE customers(cus_id INT AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(100),
email VARCHAR(100),
city VARCHAR(50),
acc_type VARCHAR(20),
acc_bal DECIMAL(10,2)
);
desc customers;

CREATE TABLE transactions(
tra_id INT AUTO_INCREMENT PRIMARY KEY,
cus_id INT,
amount DECIMAL(10,2),
tra_type VARCHAR(10),
tra_mode VARCHAR(20),
tra_date DATETIME DEFAULT CURRENT_TIMESTAMP,
FOREIGN KEY (cus_id) REFERENCES customers(cus_id)
);

